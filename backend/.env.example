NODE_ENV=production
PORT=8787
FRONTEND_ORIGIN=https://your-domain.com
CORS_ORIGINS=https://your-domain.com
JWT_SECRET=replace_with_32_plus_random_characters
COOKIE_SECURE=true
DATA_DIR=/var/lib/viewly/data
UPLOADS_DIR=/var/lib/viewly/uploads
REQUIRE_PERSISTENT_STORAGE=true
REQUIRE_PAYPAL=true
ENABLE_SELF_SERVICE_BILLING=false
OPENAI_API_KEY=replace_me
PAYPAL_CLIENT_ID=replace_me
PAYPAL_CLIENT_SECRET=replace_me
PAYPAL_ENV=live
PAYPAL_CURRENCY=EUR
PAYPAL_STUDIO_PRICE=7.99
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=gpt-compatible
VIEWLY_AI_PROVIDER=openai
AI_TIMEOUT_MS=45000
