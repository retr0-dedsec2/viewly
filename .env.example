# --- Frontend (Vite) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optionnel : si une app Next.js partage le meme fichier
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
VITE_STRIPE_CREATOR_URL=https://buy.stripe.com/creator
VITE_STRIPE_PRO_URL=https://buy.stripe.com/pro
VITE_STRIPE_AGENCY_URL=https://buy.stripe.com/agency

# --- Backend (Express, backend/server.js) ---
NODE_ENV=development
PORT=8787
# Origine du front (CORS + cookies). En prod : URL exacte du site.
FRONTEND_ORIGIN=https://your-domain.com
FRONTEND_URL=https://your-domain.com
CORS_ORIGINS=https://your-domain.com
# Production : obligatoire, 32+ caracteres aleatoires (jamais committer la vraie valeur)
JWT_SECRET=replace_with_32_plus_random_characters
JWT_EXPIRES_IN=7d
COOKIE_SECURE=true
ALLOW_INSECURE_PROD_COOKIES=false
SESSION_COOKIE_NAME=viewly_session
CSRF_COOKIE_NAME=viewly_csrf
ENABLE_BEARER_AUTH=false
JSON_BODY_LIMIT=8mb
TRUST_PROXY=
# Derriere proxy (ex. 1 sur Vercel) : definir TRUST_PROXY=1 si besoin

# Stockage fichiers (NeDB + uploads). Sur Vercel sans volume : laisser vide pour /tmp par defaut
DATA_DIR=
UPLOADS_DIR=
REQUIRE_PERSISTENT_STORAGE=true
REQUIRE_PAYPAL=true
ENABLE_SELF_SERVICE_BILLING=false

# PayPal (billing Studio)
PAYPAL_CLIENT_ID=replace_me
PAYPAL_CLIENT_SECRET=replace_me
PAYPAL_ENV=sandbox
PAYPAL_CURRENCY=EUR
PAYPAL_STUDIO_PRICE=7.99

# YouTube (backend : recherche / metadonnees)
YOUTUBE_API_KEY=your_youtube_data_api_key
YOUTUBE_TIMEOUT_MS=8000

# Limitation de debit (API)
RATE_LIMIT_MAX=600
LOGIN_RATE_LIMIT_MAX=12
REGISTER_RATE_LIMIT_MAX=10

# Premier demarrage production : compte admin initial (recommande hors Vercel)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=ChangeMe_StrongPass1
ADMIN_NAME=Viewly Admin

# Dev uniquement : jeux de donnees de demo (interdit en prod)
SEED_DEMO_DATA=false
DEMO_ADMIN_PASSWORD=
DEMO_USER_PASSWORD=

# IA
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=gpt-compatible
VIEWLY_AI_PROVIDER=openai
AI_TIMEOUT_MS=45000

# Ancien mini-serveur backend/src/server.js (Stripe checkout) — optionnel
STRIPE_SECRET_KEY=

# Variables systeme Vercel (ne pas definir en local ; injectees au deploiement)
# VERCEL=1
# VERCEL_URL=your-project.vercel.app

# Persistance NeDB vers Supabase Storage (backend)
# Necessite une cle service role (ne jamais exposer au frontend).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_BUCKET=viewly-db
